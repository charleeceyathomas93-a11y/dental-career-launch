{
  "installCommand": "cd .. && npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "buildCommand": "../../node_modules/.bin/vite build --config vite.config.ts",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
